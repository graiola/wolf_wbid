<?xml version="1.0" ?>
<launch>

    <arg name="period"     default="0.001"/>

    <param name="period"     value="$(arg period)"/>
    <param name="robot_name" value=""/>

    <!-- Load the robot -->
    <include file="$(find wolf_description_utils)/launch/upload.launch">
        <arg name="period" value="$(arg period)" />
    </include>

    <!-- IDProblem test -->
    <test test-name="wolf_id_problem_test"
         pkg="wolf_controller"
         type="test_id_problem"
         time-limit="80.0">
    </test>

</launch>
